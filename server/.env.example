# ═══════════════════════════════════════════════
#  服务端环境变量配置 — 阿里云 OSS 数据存储
#  复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════

# 服务端口
PORT=3001

# 阿里云 OSS 配置（所有 CRUD 数据存到 OSS）
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_OSS_REGION=oss-cn-shanghai
ALIYUN_OSS_BUCKET=jinbang-sync
ALIYUN_OSS_KEY=sync-store.json

# 本地回退存储路径（OSS 不可用时自动回退，可选）
SYNC_STORE_PATH=./data/sync-store.json

# JWT 密钥（用于生成用户登录 Token）
JWT_SECRET=your_jwt_secret_here

# CORS 允许的域名（生产环境配置）
CORS_ORIGIN=http://localhost:3000
