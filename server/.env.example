# ═══════════════════════════════════════════════
#  服务端环境变量配置
#  复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════

# 服务端口
PORT=3000

# 腾讯云 CloudBase 配置
TCB_ENV_ID=sjy-d0gxtaklr8e1be761
TCB_REGION=ap-shanghai

# ⚠️ 重要：Server Key 仅用于服务端，严禁暴露到前端！
# 从腾讯云控制台获取：https://console.cloud.tencent.com/tcb/env/overview
TCB_SERVER_KEY=your_server_key_here

# JWT 密钥（用于生成用户登录 Token）
JWT_SECRET=your_jwt_secret_here

# CORS 允许的域名（生产环境配置）
CORS_ORIGIN=http://localhost:5173
