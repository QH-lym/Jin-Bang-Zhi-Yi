<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- API 反向代理规则 - 将 /api/* 转发到 localhost:3001 -->
        <rule name="API Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^https?://" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3001/{R:1}" />
        </rule>
        
        <!-- Health Check 代理 -->
        <rule name="Health Proxy" stopProcessing="true">
          <match url="^health$" />
          <action type="Rewrite" url="http://localhost:3001/health" />
        </rule>
      </rules>
      <outboundRules>
        <!-- 修复重定向 URL，确保返回 HTTPS -->
        <rule name="Fix Location Header" preCondition="CheckLocationHeader">
          <match serverVariable="RESPONSE_Location" pattern="^http://localhost:3001/(.*)" />
          <action type="Rewrite" value="https://jinbangzhiyi.online/api/{R:1}" />
        </rule>
        <preConditions>
          <preCondition name="CheckLocationHeader">
            <add input="{RESPONSE_Location}" pattern="^http://localhost:3001/" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    
    <!-- 允许跨域请求 -->
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Methods" value="GET,POST,PUT,DELETE,OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type,Authorization" />
      </customHeaders>
    </httpProtocol>
    
    <!-- 启用代理 -->
    <proxy enabled="true" preserveHostHeader="false" reverseProxyHostHeader="true" />
  </system.webServer>
</configuration>
